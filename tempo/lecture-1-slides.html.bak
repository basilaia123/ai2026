<script>
    // Copy Functionality setup
    document.querySelectorAll('.code-block').forEach(block => {
        // If it doesn't already have a button, add one
        if(!block.querySelector('.copy-btn')) {
            const btn = document.createElement('button');
            btn.className = 'copy-btn';
            btn.innerText = 'áƒ™áƒáƒžáƒ˜áƒ áƒ”áƒ‘áƒ';
            
            btn.addEventListener('click', async () => {
                const textToCopy = Array.from(block.childNodes)
                    .filter(node => node !== btn)
                    .map(node => node.textContent)
                    .join('')
                    .trim();

                try {
                    await navigator.clipboard.writeText(textToCopy);
                    btn.innerText = 'áƒ“áƒáƒ™áƒáƒžáƒ˜áƒ áƒ“áƒ!';
                    btn.style.color = '#1A1A1A';
                    btn.style.background = '#C5A059';
                    
                    setTimeout(() => {
                        btn.innerText = 'áƒ™áƒáƒžáƒ˜áƒ áƒ”áƒ‘áƒ';
                        btn.style.color = '';
                        btn.style.background = '';
                    }, 2000);
                } catch (err) {
                    console.error('Failed to copy: ', err);
                }
            });
            
            block.appendChild(btn);
        }
    });

    // Sidebar logic
    const sidebar = document.getElementById('sidebar');
    const overlay = document.getElementById('overlay');
    const mainContent = document.getElementById('mainContent');
    const menuBtn = document.getElementById('menuBtn');
    const menuIcon = document.getElementById('menuIcon');
    const closeIcon = document.getElementById('closeIcon');
    let sidebarOpen = false;

    function setSidebarState(open) {
        sidebarOpen = open;
        if (open) {
            sidebar.classList.remove('-translate-x-full');
            menuIcon.classList.add('hidden');
            closeIcon.classList.remove('hidden');
            if (window.innerWidth >= 768) {
                mainContent.style.marginLeft = '18rem';
                menuBtn.style.left = '18.75rem';
            } else {
                overlay.classList.remove('hidden');
            }
        } else {
            sidebar.classList.add('-translate-x-full');
            menuIcon.classList.remove('hidden');
            closeIcon.classList.add('hidden');
            mainContent.style.marginLeft = '0';
            menuBtn.style.left = '1rem';
            overlay.classList.add('hidden');
        }
    }

    function toggleSidebar() {
        setSidebarState(!sidebarOpen);
    }

    // Close sidebar on mobile when clicking a nav link
    document.querySelectorAll('.nav-link').forEach(link => {
        link.addEventListener('click', () => {
            if (window.innerWidth < 768) setSidebarState(false);
        });
    });

    // Adjust on resize
    window.addEventListener('resize', () => {
        if (sidebarOpen && window.innerWidth >= 768) {
            overlay.classList.add('hidden');
            mainContent.style.marginLeft = '18rem';
            menuBtn.style.left = '18.75rem';
        } else if (sidebarOpen && window.innerWidth < 768) {
            overlay.classList.remove('hidden');
            mainContent.style.marginLeft = '0';
            menuBtn.style.left = '1rem';
        }
    });

    // Initialize sidebar open on desktop
    if (window.innerWidth >= 768) {
        setSidebarState(true);
    }
    
    // Active Link Highlighting
    const observerOptions = {
        root: null,
        rootMargin: '0px',
        threshold: 0.2
    };

    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                document.querySelectorAll('.nav-link').forEach(link => {
                    link.classList.remove('active');
                    if (link.getAttribute('href') === '#' + entry.target.id) {
                        link.classList.add('active');
                        
                        // Scroll nav into view if needed
                        const navContainer = document.querySelector('aside nav');
                        const linkRect = link.getBoundingClientRect();
                        const navRect = navContainer.getBoundingClientRect();
                        
                        if (linkRect.top < navRect.top || linkRect.bottom > navRect.bottom) {
                            link.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                        }
                    }
                });
            }
        });
    }, observerOptions);

    document.querySelectorAll('.topic-card').forEach(section => {
        observer.observe(section);
    });
</script>
</body>
